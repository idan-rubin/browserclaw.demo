# At least one AI provider API key is required.
# The first available model will be used as default.

# Groq (free tier, fast inference)
GROQ_API_KEY=

# Google Gemini (free tier)
GEMINI_API_KEY=

# OpenAI (paid)
OPENAI_API_KEY=

# Required: which model to use
# Valid values: groq-llama-3.3-70b, gemini-2.5-flash, gpt-5.4
MODEL=groq-llama-3.3-70b

# Optional: fallback model when primary hits rate limits
# FALLBACK_MODEL=gpt-5.4

# Server
PORT=5040

# Browser
BROWSER_HEADLESS=false
SSRF_ALLOW_PRIVATE=true

# Optional: internal auth token for frontend → browser service calls
# BROWSER_INTERNAL_TOKEN=

# Optional: rate limiting
# RATE_LIMIT_MAX=20
# RATE_LIMIT_WINDOW_MS=86400000

# Optional: session limits
# MAX_SESSIONS=10
# MAX_SESSIONS_PER_IP=1
# SESSION_MAX_DURATION_MS=300000
# MAX_AGENT_STEPS=50
